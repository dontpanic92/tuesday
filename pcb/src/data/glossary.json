{
  "schema_version": "1.0.0",
  "language": "zh-CN",
  "terms": [
    {"id": "pcb", "zh": "印制电路板", "en": "Printed Circuit Board", "abbr": "PCB", "definition": "用绝缘基材、铜层、孔和表面材料实现电气连接与机械承载的板。", "first_page": "01"},
    {"id": "schematic", "zh": "原理图", "en": "Schematic", "abbr": null, "definition": "按逻辑关系表达元件、引脚和网络的电路文档，不表示真实几何距离。", "first_page": "01"},
    {"id": "net", "zh": "网络", "en": "Net", "abbr": null, "definition": "在电气上应互相连接的一组引脚、焊盘和铜图元。", "first_page": "01"},
    {"id": "reference-designator", "zh": "位号", "en": "Reference Designator", "abbr": "RefDes", "definition": "元件实例的唯一标签，例如 R5、U1、J2。", "first_page": "02"},
    {"id": "symbol", "zh": "符号", "en": "Schematic Symbol", "abbr": null, "definition": "原理图中表示器件功能和引脚的图形模型。", "first_page": "01"},
    {"id": "footprint", "zh": "封装/焊盘图", "en": "Footprint / Land Pattern", "abbr": null, "definition": "PCB 上焊盘、孔、丝印和装配边界的几何定义。", "first_page": "01"},
    {"id": "component-body", "zh": "器件实体", "en": "Component Body", "abbr": null, "definition": "元件真实外壳占据的三维或二维投影空间。", "first_page": "19"},
    {"id": "courtyard", "zh": "庭院", "en": "Courtyard", "abbr": null, "definition": "为贴装、返修和邻件间距预留的装配边界。", "first_page": "19"},
    {"id": "pad", "zh": "焊盘", "en": "Pad", "abbr": null, "definition": "用于焊接器件引脚或连接测试点的铜区域。", "first_page": "01"},
    {"id": "track", "zh": "走线", "en": "Track / Trace", "abbr": null, "definition": "PCB 铜层上的线状导体。", "first_page": "01"},
    {"id": "via", "zh": "过孔", "en": "Via", "abbr": null, "definition": "用金属化孔连接不同铜层的结构。", "first_page": "01"},
    {"id": "pth", "zh": "金属化通孔", "en": "Plated Through Hole", "abbr": "PTH", "definition": "孔壁有铜，可用于电气连接或通孔元件。", "first_page": "01"},
    {"id": "npth", "zh": "非金属化孔", "en": "Non-Plated Through Hole", "abbr": "NPTH", "definition": "孔壁无铜，通常用于机械定位或安装。", "first_page": "01"},
    {"id": "solder-mask", "zh": "阻焊层", "en": "Solder Mask", "abbr": null, "definition": "覆盖非焊接铜面的绝缘保护层。", "first_page": "01"},
    {"id": "paste-mask", "zh": "锡膏层/钢网开口", "en": "Paste Mask", "abbr": null, "definition": "规定表面贴装焊盘上锡膏开口的制造层。", "first_page": "28"},
    {"id": "silkscreen", "zh": "丝印", "en": "Silkscreen", "abbr": null, "definition": "用于名称、方向、警告和装配标识的印刷层。", "first_page": "01"},
    {"id": "board-outline", "zh": "板框", "en": "Board Outline", "abbr": null, "definition": "定义 PCB 最终外形的闭合制造边界。", "first_page": "01"},
    {"id": "ground", "zh": "地", "en": "Ground", "abbr": "GND", "definition": "本板共同电压参考和回流网络，不是电流消失的地方。", "first_page": "02"},
    {"id": "return-path", "zh": "回流路径", "en": "Return Path", "abbr": null, "definition": "信号或电源电流返回源端所经过的导体路径。", "first_page": "01"},
    {"id": "copper-pour", "zh": "铺铜", "en": "Copper Pour", "abbr": null, "definition": "按网络和间距规则自动生成的大面积铜区域；边界本身不等于已有制造铜。", "first_page": "01"},
    {"id": "static-fill", "zh": "静态铜填充", "en": "Static Copper Fill", "abbr": null, "definition": "不会随规则或几何自动重算的固定铜图元；R1 使用 17 个 GND FILL 区域。", "first_page": "24"},
    {"id": "stitching-via", "zh": "地缝合过孔", "en": "Ground Stitching Via", "abbr": null, "definition": "连接不同层地铜、缩短回流和降低高频阻抗的过孔。", "first_page": "23"},
    {"id": "clearance", "zh": "间距", "en": "Clearance", "abbr": null, "definition": "不同铜、器件或板边之间必须保留的最小距离。", "first_page": "18"},
    {"id": "erc", "zh": "电气规则检查", "en": "Electrical Rules Check", "abbr": "ERC", "definition": "检查原理图引脚类型、未连接和电气冲突的自动规则；不能证明机械可制造。", "first_page": "17"},
    {"id": "drc", "zh": "设计规则检查", "en": "Design Rule Check", "abbr": "DRC", "definition": "检查 PCB 连通、间距、尺寸等规则；不能替代器件碰撞、热和信号完整性验证。", "first_page": "18"},
    {"id": "bom", "zh": "物料清单", "en": "Bill of Materials", "abbr": "BOM", "definition": "列出拟采购/装配元件、数量、位号、料号和封装的文件。", "first_page": "27"},
    {"id": "cpl", "zh": "元件坐标表", "en": "Component Placement List", "abbr": "CPL", "definition": "列出位号、坐标、旋转和装配面的贴装/定位文件。", "first_page": "27"},
    {"id": "dnp", "zh": "不装配", "en": "Do Not Populate", "abbr": "DNP", "definition": "PCB 保留元件位置但制造 BOM 不安装；R1 的 J2/J3 属于此状态。", "first_page": "02"},
    {"id": "gerber", "zh": "Gerber 制造文件", "en": "Gerber", "abbr": null, "definition": "描述铜、阻焊、锡膏、丝印和板框几何的制造数据。", "first_page": "28"},
    {"id": "manifest", "zh": "发布清单", "en": "Release Manifest", "abbr": null, "definition": "记录版本、统计、检查结果、交付物和哈希的发布文件。", "first_page": "28"},
    {"id": "usb", "zh": "通用串行总线", "en": "Universal Serial Bus", "abbr": "USB", "definition": "本板用于供电和与主机通信的串行接口。", "first_page": "04"},
    {"id": "usb-c", "zh": "USB Type-C", "en": "USB Type-C", "abbr": "USB-C", "definition": "可翻转连接器体系；R1 只实现 USB 2.0 设备和受电端 CC 检测。", "first_page": "05"},
    {"id": "vbus", "zh": "USB 总线电源", "en": "USB VBUS", "abbr": "VBUS", "definition": "J1 提供的约 5 V 电源；板内网络名为 VBUS_IN。", "first_page": "07"},
    {"id": "cc", "zh": "配置通道", "en": "Configuration Channel", "abbr": "CC", "definition": "USB-C 用于方向、角色和供电能力检测的引脚；R1 用 R1/R2 下拉。", "first_page": "07"},
    {"id": "rd", "zh": "受电端下拉", "en": "Sink Pull-Down", "abbr": "Rd", "definition": "USB-C 受电设备在 CC1/CC2 上使用的下拉电阻。", "first_page": "07"},
    {"id": "differential-pair", "zh": "差分对", "en": "Differential Pair", "abbr": null, "definition": "用两根互补信号线传输差分信息；USB D+ 与 D- 构成一对。", "first_page": "08"},
    {"id": "skew", "zh": "偏斜", "en": "Skew", "abbr": null, "definition": "差分对两条路径长度或传播时间之差；长度小不等于阻抗合格。", "first_page": "08"},
    {"id": "impedance", "zh": "阻抗", "en": "Impedance", "abbr": null, "definition": "交流下电压与电流的复数关系；USB 走线阻抗取决于实际生产叠层和几何。", "first_page": "08"},
    {"id": "esd", "zh": "静电放电", "en": "Electrostatic Discharge", "abbr": "ESD", "definition": "短时高压放电事件；U2 用于把 USB 数据线上的事件导向参考网络。", "first_page": "03"},
    {"id": "buck", "zh": "降压型开关变换器", "en": "Buck Converter", "abbr": null, "definition": "用开关、电感和电容把较高直流电压高效变为较低电压。", "first_page": "09"},
    {"id": "switch-node", "zh": "开关节点", "en": "Switch Node", "abbr": null, "definition": "U3 与 L1 之间高速跃变的 BUCK_SW 网络，具有高 dv/dt 和 EMI 风险。", "first_page": "09"},
    {"id": "feedback", "zh": "反馈", "en": "Feedback", "abbr": "FB", "definition": "把输出分压送回稳压器以调节输出；R5/R6 构成 BUCK_FB 分压。", "first_page": "09"},
    {"id": "load-switch", "zh": "负载开关", "en": "Load Switch", "abbr": null, "definition": "用逻辑信号控制电源通断并可提供限流/热保护的高侧器件。", "first_page": "10"},
    {"id": "current-limit", "zh": "限流", "en": "Current Limit", "abbr": null, "definition": "负载超过设定值时限制输出电流；R7/R8 设置 U4/U5 的典型阈值。", "first_page": "10"},
    {"id": "decoupling", "zh": "去耦", "en": "Decoupling", "abbr": null, "definition": "用近端电容向快速负载提供瞬态电流并缩小高频回路。", "first_page": "03"},
    {"id": "bulk-capacitor", "zh": "储能/大容量电容", "en": "Bulk Capacitor", "abbr": null, "definition": "主要服务较低频负载变化和能量储备的电容。", "first_page": "03"},
    {"id": "mcu", "zh": "微控制器", "en": "Microcontroller Unit", "abbr": "MCU", "definition": "集成 CPU、存储器和外设的控制芯片；R1 使用 U1 CH32V203K8T6。", "first_page": "03"},
    {"id": "gpio", "zh": "通用输入输出", "en": "General-Purpose Input/Output", "abbr": "GPIO", "definition": "可由固件配置为数字输入、输出或复用功能的引脚。", "first_page": "04"},
    {"id": "pwm", "zh": "脉宽调制", "en": "Pulse-Width Modulation", "abbr": "PWM", "definition": "通过改变周期内高电平比例控制平均效果；R1 四路 PWM 共用 TIM3 频率。", "first_page": "04"},
    {"id": "uart", "zh": "通用异步收发器", "en": "Universal Asynchronous Receiver/Transmitter", "abbr": "UART", "definition": "按波特率、数据位、校验和停止位传输的异步串口；R1 为 3.3 V TTL/CMOS。", "first_page": "04"},
    {"id": "swd", "zh": "串行线调试", "en": "Serial Wire Debug", "abbr": "SWD", "definition": "使用 SWDIO、SWCLK、NRST、电源和地进行编程调试的接口。", "first_page": "11"},
    {"id": "high-impedance", "zh": "高阻态", "en": "High Impedance", "abbr": "Hi-Z", "definition": "引脚既不主动拉高也不主动拉低的状态。", "first_page": "02"},
    {"id": "absolute-maximum", "zh": "绝对最大额定值", "en": "Absolute Maximum Rating", "abbr": null, "definition": "不得长期工作的损坏边界，不是推荐工作点。", "first_page": "06"},
    {"id": "recommended-operating", "zh": "推荐工作条件", "en": "Recommended Operating Conditions", "abbr": null, "definition": "数据手册保证正常功能所要求的电压、温度等范围。", "first_page": "06"},
    {"id": "design-state", "zh": "设计值", "en": "Design Value", "abbr": null, "definition": "最终源中采用的标称值，不表示已测量。", "first_page": "00"},
    {"id": "calculated-state", "zh": "计算值", "en": "Calculated Value", "abbr": null, "definition": "由设计值、公式或 CAD 几何推导的结果。", "first_page": "00"},
    {"id": "expected-state", "zh": "预期值/行为", "en": "Expected Value / Behavior", "abbr": null, "definition": "依据机理或规格预测、尚未由实物确认的结果。", "first_page": "00"},
    {"id": "measured-state", "zh": "实测值", "en": "Measured Value", "abbr": null, "definition": "来自装配实物和仪器的原始或处理后数据；当前 R1 事实库尚无。", "first_page": "00"},
    {"id": "unverified-state", "zh": "待验证", "en": "Unverified", "abbr": null, "definition": "需要进一步数据手册复核、生产信息或实物实验才能确认。", "first_page": "00"}
  ]
}
