    },
    {
      "id": "buck-feedback",
      "name_zh": "SY8089 输出反馈",
      "equation": "V_OUT = V_FB × (1 + R_TOP / R_BOTTOM)",
      "variables": {"V_FB": "典型 0.6 V", "R_TOP": "R5 = 453 kΩ", "R_BOTTOM": "R6 = 100 kΩ"},
      "calculation": {"expression": "0.6 × (1 + 453/100)", "result": 3.318, "unit": "V"},
      "interpretation": "计算值接近 3.3 V；电阻误差、FB 基准误差、负载和布局会改变实物结果。",
      "state": "calculated",
      "hardware_result": "unverified",
      "sources": ["final-project-archive", "datasheet-sy8089"]
    },
    {
