      "state": "design",
      "sources": ["tutorial-toc"]
    },
    {
      "id": "resistor-power",
      "name_zh": "电阻功耗",
      "equation": "P = V × I = I² × R = V² / R",
      "variables": {"P": "功率，W", "V": "电阻两端电压，V", "I": "电流，A", "R": "电阻，Ω"},
