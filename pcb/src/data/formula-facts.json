      "project_uses": ["检查 0603 100 mW 电阻裕量"],
      "state": "design",
      "sources": ["final-project-archive"]
    },
    {
      "id": "voltage-drop",
      "name_zh": "导体或开关压降",
      "equation": "V_DROP = I × R_PATH",
